---
import { CONTACTS } from '../lib/contacts';
import SocialIcon from './SocialIcon.astro';
---
<div class="sticky-cta" id="stickyCTA" aria-label="Быстрые контакты">
  <a href={CONTACTS.whatsapp} target="_blank" rel="noopener noreferrer" class="cta-tile cta-wa" aria-label="WhatsApp">
    <SocialIcon name="whatsapp" />
    <span>WhatsApp</span>
  </a>
  <a href={`tel:${CONTACTS.phoneE164}`} class="cta-tile cta-call" aria-label="Позвонить">
    <SocialIcon name="phone" />
    <span>Позвонить</span>
  </a>
</div>

<style>
  .sticky-cta {
    display: none;
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 40;
    background: rgba(255,255,255,0.96);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-top: 1px solid var(--c-border);
    padding: 8px 6px calc(8px + env(safe-area-inset-bottom));
    box-shadow: 0 -8px 24px rgba(0,0,0,0.06);
  }
  @media (max-width: 900px) {
    .sticky-cta { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; padding: 10px 12px calc(10px + env(safe-area-inset-bottom)); }
    /* Когда открыто бургер-меню — прячем sticky bar */
    body.menu-open .sticky-cta { display: none; }
    /* Отступ для контента, чтобы последняя секция не пряталась под баром */
    body { padding-bottom: 72px; }
  }
  .cta-tile {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 8px;
    border-radius: 12px;
    color: #fff;
    font-size: .92rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform var(--t-fast), opacity var(--t-fast);
    min-height: 48px;
  }
  .cta-tile :global(svg) { width: 18px; height: 18px; }
  .cta-tile:active { transform: scale(0.97); opacity: 0.9; }
  .cta-wa { background: #25d366; }
  .cta-call { background: var(--c-red); }
</style>
