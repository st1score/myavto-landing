---
export interface Props {
  title?: string;
  subtitle?: string;
  logos: { name: string; src: string; href?: string }[];
  speed?: number; // sec for one loop
  dark?: boolean;
}

const { title, subtitle, logos, speed = 40, dark = false } = Astro.props;
// Дублируем массив для бесшовной прокрутки
const doubled = [...logos, ...logos];
---
<section class:list={["marquee-section", { dark }]}>
  <div class="container marquee-head">
    {title && <h2 class="reveal">{title}</h2>}
    {subtitle && <p class="muted reveal reveal-delay-1">{subtitle}</p>}
  </div>

  <!-- Десктоп: бесконечная маркиза -->
  <div class="marquee desktop-only" style={`--speed: ${speed}s`}>
    <div class="marquee-track">
      {doubled.map((l) => (
        l.href ? (
          <a href={l.href} class="marquee-item" aria-label={l.name}>
            <img src={l.src} alt={l.name} loading="lazy" />
          </a>
        ) : (
          <div class="marquee-item" aria-label={l.name}>
            <img src={l.src} alt={l.name} loading="lazy" />
          </div>
        )
      ))}
    </div>
  </div>

  <!-- Мобила: статичная сетка 3×N, все логотипы видны сразу -->
  <div class="container logos-grid mobile-only">
    {logos.map((l) => (
      l.href ? (
        <a href={l.href} class="logo-cell" aria-label={l.name}>
          <img src={l.src} alt={l.name} loading="lazy" />
        </a>
      ) : (
        <div class="logo-cell" aria-label={l.name}>
          <img src={l.src} alt={l.name} loading="lazy" />
        </div>
      )
    ))}
  </div>
</section>

<style>
  .marquee-section { padding: 56px 0; }
  .marquee-section.dark {
    background: var(--c-black);
    color: #fff;
  }
  .marquee-head { text-align: center; margin-bottom: 32px; }
  .marquee-head h2 { font-size: clamp(1.4rem, 2.4vw, 1.9rem); margin-bottom: 8px; }
  .marquee-section.dark h2 { color: #fff; }
  .marquee-section.dark .muted { color: rgba(255,255,255,0.6); }

  .marquee {
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
  }
  .marquee-track {
    display: flex;
    gap: 56px;
    width: max-content;
    animation: marquee var(--speed, 40s) linear infinite;
  }
  @media (max-width: 900px) {
    /* На планшетах оставляем маркизу, но в 1.6 раза медленнее */
    .marquee-track { animation-duration: calc(var(--speed, 40s) * 1.6); }
  }
  @media (max-width: 640px) {
    .marquee-section { padding: 32px 0; }
    .marquee-head { margin-bottom: 20px; }
    .marquee-head h2 { font-size: 1.2rem; }
  }

  /* Переключение desktop/mobile вариантов */
  .desktop-only { display: block; }
  .mobile-only { display: none; }
  @media (max-width: 640px) {
    .desktop-only { display: none; }
    .mobile-only { display: grid; }
  }

  /* Сетка логотипов на мобиле */
  .logos-grid {
    /* minmax(0, 1fr) — иначе 1fr разъезжается из-за intrinsic min-size */
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    padding-top: 8px;
  }
  @media (max-width: 340px) {
    .logos-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
  }
  .logo-cell {
    height: 64px;
    background: #fafafa;
    border: 1px solid var(--c-border);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    transition: transform var(--t-fast), border-color var(--t-fast);
    -webkit-tap-highlight-color: transparent;
    overflow: hidden;
  }
  .marquee-section.dark .logo-cell {
    background: #fafafa;
    border-color: rgba(255,255,255,0.08);
  }
  .logo-cell img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .marquee-section.dark .logo-cell img {
    filter: drop-shadow(0 0 6px rgba(255,255,255,0.08));
  }
  .logo-cell:active { transform: scale(0.96); border-color: var(--c-red); }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .marquee-item {
    flex-shrink: 0;
    width: 120px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--t-fast);
  }
  .marquee-item img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.92;
    transition: opacity var(--t-fast), transform var(--t-fast), filter var(--t-fast);
  }
  /* В тёмном варианте логотипы остаются цветными, но получают мягкое свечение */
  .marquee-section.dark .marquee-item img {
    filter: drop-shadow(0 0 8px rgba(255,255,255,0.08));
  }
  .marquee-item:hover img {
    opacity: 1;
    transform: scale(1.1);
    filter: drop-shadow(0 4px 12px rgba(229,9,20,0.25));
  }
</style>
