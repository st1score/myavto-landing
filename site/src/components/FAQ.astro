---
const FAQ_ITEMS = [
  {
    q: 'Я не знаю код двигателя — как мне найти запчасти?',
    a: 'Напишите в WhatsApp марку, модель и год авто (например «Toyota Camry 2007 2.4»). Мы за пару минут определим какой у вас двигатель и подберём поршни, кольца, вкладыши. Если двигатель свапнут — пришлите фото маркировки на блоке цилиндров или ГБЦ.',
  },
  {
    q: 'Как узнать цену и наличие запчастей?',
    a: 'Цены и точное наличие — по WhatsApp. На сайте мы показываем какие бренды и размеры доступны под ваш двигатель. Цены могут меняться в зависимости от поставщика, поэтому актуальную стоимость даём через менеджера.',
  },
  {
    q: 'Какие бренды запчастей вы возите?',
    a: 'Поршни и гильзы — TEIKIN, ND, IZUMI, NM. Поршневые кольца — RIK, TP, NPR. Вкладыши коренные/шатунные/балансира/распредвала — Taiho, NDC. Прокладки ГБЦ и ремкомплекты — NM. Водяные помпы и ролики — GMB, NPW. Сальники и маслосъёмные колпачки — NOK. Все бренды японские.',
  },
  {
    q: 'Как и сколько идёт доставка по Казахстану?',
    a: 'По Алматы — Яндекс.Такси или inDrive в день заказа. По регионам РК: автобус (самый дешёвый и быстрый вариант, 1-2 дня), Сайран Такси, СДЭК или Казпочта (1-5 дней). Срочно самолётом — AVS грузоперевозки. Способ согласуем при заказе.',
  },
  {
    q: 'Какие способы оплаты?',
    a: 'Перевод по номеру телефона, Halyk Bank, наличные при самовывозе в Алматы. Для юр.лиц — безналичный расчёт с НДС, ЭСФ, полный пакет закрывающих документов. Для постоянных СТО и моторных цехов — отсрочка платежа.',
  },
  {
    q: 'Что значат размеры STD, 0.25, 0.50, 0.75?',
    a: 'Это ремонтные размеры поршней, колец и вкладышей. STD — стандартный (заводской) размер. 0.25, 0.50, 0.75 мм — увеличенные размеры для расточенного блока или шлифованного коленвала. Какой размер нужен — зависит от состояния двигателя после дефектовки.',
  },
  {
    q: 'Даёте ли гарантию на запчасти?',
    a: 'На все оригинальные японские бренды (TEIKIN, NPR, RIK, Taiho, NDC, NM, GMB, NOK) — заводская гарантия производителя. Заводской брак — обмен в течение 14 дней при сохранении упаковки. Гарантия не распространяется на износ от неправильной сборки или эксплуатации.',
  },
  {
    q: 'Что если нужной позиции нет в наличии?',
    a: 'Привозим под заказ из Японии. Срок 7-14 дней в зависимости от поставщика. Самые ходовые позиции (поршни и кольца на популярные двигатели Toyota/Nissan/Mitsubishi/Mazda, вкладыши, прокладки ГБЦ) — практически всегда в наличии в Алматы.',
  },
  {
    q: 'Работаете с юр.лицами и СТО?',
    a: 'Да. ТОО, ИП, безналичный расчёт, НДС, ЭСФ, СНТ. Полный пакет закрывающих документов. Для проверенных СТО и моторных цехов — отсрочка платежа 7-30 дней после 2-3 заказов.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a },
  })),
};
---

<section class="faq-section" id="faq">
  <div class="container">
    <div class="faq-head reveal">
      <span class="eyebrow">FAQ</span>
      <h2>Частые вопросы</h2>
      <p>Доставка, оплата, гарантия, подбор — всё что нужно знать перед заказом.</p>
    </div>

    <div class="faq-list">
      {FAQ_ITEMS.map((item, i) => (
        <details class="faq-item reveal" name="faq" open={i === 0}>
          <summary>
            <span>{item.q}</span>
            <span class="faq-chev" aria-hidden="true">+</span>
          </summary>
          <div class="faq-answer">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<style>
  .faq-section { padding: 80px 0; }
  @media (max-width: 768px) { .faq-section { padding: 48px 0; } }

  .faq-head { text-align: center; max-width: 720px; margin: 0 auto 48px; }
  .faq-head .eyebrow {
    display: inline-block;
    font-size: .82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-red);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .faq-head h2 { margin-bottom: 16px; }
  .faq-head p { color: var(--c-text-dim); }

  .faq-list { max-width: 820px; margin: 0 auto; }
  .faq-item {
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    margin-bottom: 12px;
    background: #fff;
    overflow: hidden;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .faq-item[open] { border-color: var(--c-red); box-shadow: var(--shadow-sm); }
  .faq-item summary {
    padding: 20px 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-weight: 600;
    font-size: 1.02rem;
    color: var(--c-text);
    list-style: none;
    user-select: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover { color: var(--c-red); }
  .faq-chev {
    flex-shrink: 0;
    width: 28px; height: 28px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 50%;
    background: var(--c-bg-soft);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--c-text);
    transition: all var(--t-fast);
  }
  .faq-item[open] .faq-chev { background: var(--c-red); color: #fff; transform: rotate(45deg); }
  .faq-answer {
    padding: 0 24px 22px;
    color: var(--c-text-dim);
    line-height: 1.65;
  }
  .faq-answer p { margin: 0; }
  @media (max-width: 640px) {
    .faq-item summary { padding: 16px 18px; font-size: .95rem; }
    .faq-answer { padding: 0 18px 18px; font-size: .94rem; }
  }
</style>
