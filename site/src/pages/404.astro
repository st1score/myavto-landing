---
import Base from '../layouts/Base.astro';
---
<Base
  title="404 — страница не найдена | MY AVTO"
  description="Запрошенная страница не найдена. Возвращайтесь на главную или найдите свой двигатель в каталоге."
  noindex
>
  <section class="nf-section">
    <div class="nf-bg">
      <div class="nf-glow nf-glow-1"></div>
      <div class="nf-glow nf-glow-2"></div>
    </div>
    <div class="container nf-inner">
      <div class="nf-number">404</div>
      <h1 class="nf-title">Двигатель не найден<br /><span class="accent-text">в нашем каталоге</span></h1>
      <p class="nf-lead">
        Возможно, эта модификация ещё не в базе или адрес введён с ошибкой.
        Напишите код двигателя — найдём вручную.
      </p>
      <div class="nf-cta">
        <a href="/" class="btn">На главную</a>
        <a href="https://wa.me/77015509377" class="btn btn-ghost btn-on-dark" target="_blank" rel="noopener">Спросить в WhatsApp</a>
      </div>
      <div class="nf-suggest">
        <p class="muted small">Возможно, вам нужно одно из этих:</p>
        <div class="nf-links">
          <a href="/toyota/">Toyota</a>
          <a href="/nissan/">Nissan</a>
          <a href="/mitsubishi/">Mitsubishi</a>
          <a href="/mazda/">Mazda</a>
          <a href="/zapchasti/porshni/">Все поршни</a>
          <a href="/zapchasti/koltsa-porshnevye/">Все кольца</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf-section {
    position: relative;
    background: var(--c-black);
    color: #fff;
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 80px 0;
    overflow: hidden;
    isolation: isolate;
  }
  .nf-bg { position: absolute; inset: 0; z-index: -1; }
  .nf-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: drift 18s ease-in-out infinite;
  }
  .nf-glow-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--c-red) 0%, transparent 70%);
    top: -150px; right: -120px;
  }
  .nf-glow-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, #6b0610 0%, transparent 70%);
    bottom: -180px; left: -120px;
    animation-delay: -9s;
  }
  .nf-inner { text-align: center; max-width: 720px; }
  .nf-number {
    font-size: clamp(7rem, 16vw, 11rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.06em;
    background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.2) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 16px;
    animation: floaty 4s ease-in-out infinite;
  }
  @keyframes floaty {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .nf-title { color: #fff; font-size: clamp(1.6rem, 4vw, 2.6rem); margin-bottom: 16px; }
  .accent-text {
    background: linear-gradient(135deg, var(--c-red) 0%, #ff5760 60%, #ff8a92 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .nf-lead {
    color: rgba(255,255,255,0.75);
    font-size: 1.1rem;
    max-width: 540px;
    margin: 0 auto 28px;
  }
  .nf-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px; }
  .btn-on-dark { color: #fff !important; border-color: rgba(255,255,255,0.2); }
  .btn-on-dark:hover { background: #fff; color: var(--c-black) !important; border-color: #fff; }
  .nf-suggest p { margin-bottom: 14px; }
  .nf-links { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .nf-links a {
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    font-size: .9rem;
    color: #fff;
    transition: all var(--t-fast);
  }
  .nf-links a:hover { background: var(--c-red); border-color: var(--c-red); transform: translateY(-2px); }
</style>
