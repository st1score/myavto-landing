---
import Base from '../layouts/Base.astro';
import LogoMarquee from '../components/LogoMarquee.astro';
import EnginePickerForm from '../components/EnginePickerForm.astro';
import FAQ from '../components/FAQ.astro';
import { getEngines, getBrandStats } from '../lib/db';
import { brandSlug } from '../lib/slugs';

const engines = await getEngines();
const brands = await getBrandStats();
const totalEngines = engines.length;

// Популярные: сначала с is_priority, потом fallback — известные двигатели
const PRIORITY_CODES = ['1KZ', '2JZ', '2GR', '1MZ', '1ZZ', '2AZ', '1GR', 'VQ35DE', '4G63', '4M40', 'EJ20', '1JZGTE'];
let popularEngines = engines.filter((e) => e.is_priority).slice(0, 8);
if (popularEngines.length < 8) {
  const taken = new Set(popularEngines.map((e) => e.engine_code));
  for (const code of PRIORITY_CODES) {
    if (popularEngines.length >= 8) break;
    const found = engines.find((e) => e.engine_code === code && !taken.has(code));
    if (found) { popularEngines.push(found); taken.add(code); }
  }
}

function engineUrl(brand: string, code: string) {
  return `/${brandSlug[brand] ?? brand.toLowerCase()}/dvigateli/${code.toLowerCase().replace(/[\/\s]+/g, '-')}/`;
}

const autoBrands = [
  { name: 'Toyota', src: '/assets/brands/toyota.png', href: '/toyota/' },
  { name: 'Nissan', src: '/assets/brands/nissan.png', href: '/nissan/' },
  { name: 'Mitsubishi', src: '/assets/brands/mitsubishi.png', href: '/mitsubishi/' },
  { name: 'Mazda', src: '/assets/brands/mazda.png', href: '/mazda/' },
  { name: 'Honda', src: '/assets/brands/honda.png' },
  { name: 'Subaru', src: '/assets/brands/subaru.png' },
  { name: 'Suzuki', src: '/assets/brands/suzuki.png' },
  { name: 'Hyundai', src: '/assets/brands/hyundai.png' },
  { name: 'Kia', src: '/assets/brands/kia.png' },
];

const partsBrands = [
  { name: 'TEIKIN', src: '/assets/parts-brands/teikin.png', href: '/brendy/teikin/' },
  { name: 'ND', src: '/assets/parts-brands/nd.png', href: '/brendy/nd/' },
  { name: 'IZUMI', src: '/assets/parts-brands/izumi.png', href: '/brendy/izumi/' },
  { name: 'NM', src: '/assets/parts-brands/nm.png', href: '/brendy/nm/' },
  { name: 'NPR', src: '/assets/parts-brands/npr.png', href: '/brendy/npr/' },
  { name: 'RIK', src: '/assets/parts-brands/riken.png', href: '/brendy/rik/' },
  { name: 'TP', src: '/assets/parts-brands/tp.png', href: '/brendy/tp/' },
  { name: 'TAIHO', src: '/assets/parts-brands/taiho.png', href: '/brendy/taiho/' },
  { name: 'NDC', src: '/assets/parts-brands/ndc.png', href: '/brendy/ndc/' },
  { name: 'GMB', src: '/assets/parts-brands/gmb.png', href: '/brendy/gmb/' },
  { name: 'NPW', src: '/assets/parts-brands/npw.png', href: '/brendy/npw/' },
  { name: 'NOK', src: '/assets/parts-brands/nm.png', href: '/brendy/nok/' },
];

const brandLogoMap: Record<string, string> = {
  Toyota: '/assets/brands/toyota.png',
  Nissan: '/assets/brands/nissan.png',
  Mitsubishi: '/assets/brands/mitsubishi.png',
  Mazda: '/assets/brands/mazda.png',
};
---

<Base
  title="Запчасти для капиталки двигателя в Алматы | Поршни, кольца — MY AVTO"
  description="Поршни, кольца, вкладыши, прокладки ГБЦ для японских авто. Toyota, Nissan, Mitsubishi, Mazda. Магазин в Алматы (ТЦ CarCity бутик 135В), доставка по Казахстану."
  keywords="запчасти для капиталки двигателя Алматы, поршни Toyota Алматы, кольца поршневые, MY AVTO"
  canonical="/"
>
  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero-bg" id="hero-bg">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
      <div class="grid-overlay"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-eyebrow reveal">
        <span class="dot"></span>В наличии · Алматы · Доставка по РК
      </div>
      <h1 class="hero-title reveal reveal-delay-1">
        Запчасти для<br />
        <span class="accent-text">капитального ремонта</span><br />
        двигателя
      </h1>
      <p class="hero-sub reveal reveal-delay-2">
        Поршни, кольца, вкладыши, прокладки ГБЦ для Toyota, Nissan, Mitsubishi, Mazda
        и других японских авто. Прямые поставки от TEIKIN, IZUMI, NPR, RIK.
      </p>
      <div class="hero-cta reveal reveal-delay-3">
        <a href="#picker" class="btn">Подобрать запчасти</a>
        <a href="/zapchasti/porshni/" class="btn btn-ghost btn-on-dark">Открыть каталог</a>
      </div>
    </div>

    <div class="stat-bar container">
      <div class="stat reveal">
        <div class="stat-num" data-counter={totalEngines}>0</div>
        <div class="stat-label">двигателей в каталоге</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat reveal reveal-delay-1">
        <div class="stat-num" data-counter="20" data-suffix="+">0</div>
        <div class="stat-label">брендов запчастей</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat reveal reveal-delay-2">
        <div class="stat-num" data-counter="15" data-suffix=" лет">0</div>
        <div class="stat-label">на рынке Алматы</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat reveal reveal-delay-3">
        <div class="stat-num">24/7</div>
        <div class="stat-label">приём заказов в WhatsApp</div>
      </div>
    </div>
  </section>

  <!-- AUTO BRANDS MARQUEE -->
  <LogoMarquee
    title="Запчасти под популярные японские марки"
    subtitle="Прямые поставки. Полный каталог моторов с поршнями и кольцами"
    logos={autoBrands}
    speed={50}
  />

  <!-- ENGINE PICKER FORM -->
  <EnginePickerForm />

  <!-- PARTS BRANDS MARQUEE — DARK -->
  <LogoMarquee
    title="Бренды запчастей"
    subtitle="Прямые поставки от японских производителей с гарантией качества"
    logos={partsBrands}
    speed={40}
    dark={true}
  />

  <!-- HOW IT WORKS -->
  <section class="how-section">
    <div class="container">
      <div class="section-title reveal">
        <span class="eyebrow">Процесс</span>
        <h2>Как купить запчасти</h2>
        <p>От запроса до получения — обычно 1 день в Алматы, 2–5 в регионах</p>
      </div>
      <div class="steps">
        <div class="step reveal">
          <div class="step-num">01</div>
          <h3>Напишите номер двигателя</h3>
          <p class="muted">WhatsApp или прямо на сайте найдите ваш двигатель — например, 1KZ или 2JZ.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step reveal reveal-delay-1">
          <div class="step-num">02</div>
          <h3>Подбираем варианты</h3>
          <p class="muted">Покажем все доступные бренды (TEIKIN, IZUMI, NPR…) и размеры с актуальной ценой.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step reveal reveal-delay-2">
          <div class="step-num">03</div>
          <h3>Получаете заказ</h3>
          <p class="muted">Курьер по Алматы в день оплаты. По РК — автобус, авиа, Kazpost, Indriver.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="benefits-section">
    <div class="container">
      <div class="grid cols-3">
        <div class="benefit reveal">
          <div class="benefit-icon">⚡</div>
          <h3>Подбор за 10 минут</h3>
          <p class="muted">Напишите код двигателя или марку/год авто — найдём запчасти и пришлём цены в WhatsApp.</p>
        </div>
        <div class="benefit reveal reveal-delay-1">
          <div class="benefit-icon">🚚</div>
          <h3>Доставка по Казахстану</h3>
          <p class="muted">Автобусом, СДЭК, Казпочта, AVS самолётом. Inter-city за 1-3 дня.</p>
        </div>
        <div class="benefit reveal reveal-delay-2">
          <div class="benefit-icon">✓</div>
          <h3>Гарантия и возврат</h3>
          <p class="muted">Заводская гарантия на запчасть. Обмен и возврат в течение 14 дней.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ />

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box reveal">
        <div class="cta-glow"></div>
        <div class="cta-content">
          <h2>Не нашли свой двигатель?</h2>
          <p>Напишите код двигателя в WhatsApp — найдём, привезём, доставим.</p>
          <a href="https://wa.me/77015509377" class="btn" target="_blank" rel="noopener">Написать в WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    background: var(--c-black);
    color: #fff;
    padding: 120px 0 0;
    overflow: hidden;
    isolation: isolate;
  }
  @media (max-width: 768px) { .hero { padding: 64px 0 0; } }
  @media (max-width: 480px) { .hero { padding: 48px 0 0; } }
  .hero-bg { position: absolute; inset: 0; z-index: -1; overflow: hidden; transition: transform 200ms var(--ease); }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
    animation: drift 20s ease-in-out infinite;
    will-change: transform;
  }
  .glow-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(--c-red) 0%, transparent 70%);
    top: -200px; right: -100px;
  }
  .glow-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, #6b0610 0%, transparent 70%);
    bottom: -150px; left: -100px;
    animation-delay: -10s;
    animation-duration: 25s;
  }
  /* На мобиле упрощаем glow для производительности */
  @media (max-width: 768px) {
    .glow { filter: blur(60px); animation: none; }
    .glow-1 { width: 360px; height: 360px; top: -120px; right: -60px; }
    .glow-2 { width: 320px; height: 320px; bottom: -100px; left: -60px; }
    .grid-overlay { background-size: 40px 40px; }
  }
  @keyframes drift {
    0%, 100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.08); }
    66% { transform: translate(-30px, 40px) scale(0.95); }
  }
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }
  .hero-inner {
    position: relative;
    text-align: center;
    padding-bottom: 64px;
  }
  @media (max-width: 640px) { .hero-inner { padding-bottom: 40px; } }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    font-size: .82rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 32px;
    backdrop-filter: blur(8px);
  }
  .hero-eyebrow .dot {
    width: 6px; height: 6px;
    background: #4ade80;
    border-radius: 50%;
    box-shadow: 0 0 8px #4ade80;
  }
  .hero-title {
    font-size: clamp(2.2rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: 24px;
    color: #fff;
  }
  @media (max-width: 480px) {
    .hero-title { font-size: 2rem; line-height: 1.1; }
    .hero-sub { font-size: 1rem; margin-bottom: 24px; }
    .hero-eyebrow { font-size: .74rem; padding: 6px 12px; margin-bottom: 20px; }
  }
  .accent-text {
    background: linear-gradient(135deg, var(--c-red) 0%, #ff5760 60%, #ff8a92 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .hero-sub {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: rgba(255,255,255,0.75);
    max-width: 640px;
    margin: 0 auto 40px;
    line-height: 1.55;
  }
  .hero-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  @media (max-width: 480px) {
    .hero-cta { flex-direction: column; gap: 10px; }
    .hero-cta .btn { width: 100%; }
  }
  .btn-on-dark { color: #fff !important; border-color: rgba(255,255,255,0.2); }
  .btn-on-dark:hover {
    background: #fff;
    color: var(--c-black) !important;
    border-color: #fff;
  }

  /* STAT BAR */
  .stat-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 32px 24px;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(8px);
    border-top: 1px solid rgba(255,255,255,0.08);
    max-width: var(--maxw);
  }
  .stat { text-align: center; }
  .stat-num {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 8px;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: .85rem;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.1); }
  @media (max-width: 768px) {
    .stat-bar { grid-template-columns: 1fr 1fr; gap: 24px 16px; padding: 24px 16px; }
    .stat-divider { display: none; }
  }
  @media (max-width: 480px) {
    .stat-num { font-size: 1.6rem; }
    .stat-label { font-size: .72rem; }
  }

  /* BRAND CARDS */
  .brand-card {
    padding: 28px;
    min-height: 180px;
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 24px;
    align-items: center;
  }
  .brand-logo {
    width: 72px;
    height: 72px;
    object-fit: contain;
    opacity: 0.9;
    transition: transform var(--t-med), opacity var(--t-fast);
  }
  .brand-card:hover .brand-logo {
    opacity: 1;
    transform: scale(1.08) rotate(-3deg);
  }
  .brand-card-content h3 { font-size: 1.5rem; margin: 0 0 6px; }
  .brand-card-num {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--c-black);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  @media (max-width: 640px) {
    .brand-card { padding: 20px; min-height: 0; gap: 16px; }
    .brand-logo { width: 56px; height: 56px; }
    .brand-card-content h3 { font-size: 1.25rem; }
    .brand-card-num { font-size: 1.9rem; }
  }
  .brand-card:hover .brand-card-num {
    background: linear-gradient(135deg, var(--c-red) 0%, #ff5760 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ENGINE CARDS */
  .engine-card { padding: 24px; position: relative; }
  .brand-tag {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: .72rem;
    margin-bottom: 8px;
  }
  .engine-card h3 {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
  }

  /* HOW IT WORKS */
  .how-section { background: var(--c-bg-soft); }
  .steps {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 24px;
    align-items: stretch;
  }
  .step {
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    padding: 32px;
    transition: all var(--t-med);
  }
  @media (max-width: 640px) {
    .step { padding: 24px; }
    .step-num { font-size: 2.2rem; margin-bottom: 10px; }
  }
  .step:hover { border-color: var(--c-black); box-shadow: var(--shadow-lg); transform: translateY(-4px); }
  .step-num {
    font-size: 3rem;
    font-weight: 800;
    color: var(--c-red);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 16px;
  }
  .step h3 { margin-bottom: 8px; }
  .step p { margin: 0; font-size: .95rem; }
  .step-arrow {
    align-self: center;
    color: var(--c-text-faint);
    font-size: 2rem;
    animation: arrow-pulse 2.5s ease-in-out infinite;
  }
  @keyframes arrow-pulse {
    0%, 100% { transform: translateX(0); opacity: 0.5; }
    50% { transform: translateX(6px); opacity: 1; }
  }
  @media (max-width: 900px) {
    .steps { grid-template-columns: 1fr; }
    .step-arrow { display: none; }
  }

  /* BENEFITS */
  .benefit { text-align: left; padding: 8px; }
  .benefit-icon {
    width: 64px; height: 64px;
    display: flex; align-items: center; justify-content: center;
    background: var(--c-bg-soft);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    font-size: 1.8rem;
    margin-bottom: 20px;
    transition: all var(--t-med);
  }
  .benefit:hover .benefit-icon {
    background: var(--c-black);
    color: #fff;
    transform: rotate(-6deg) scale(1.05);
  }
  .benefit h3 { font-size: 1.15rem; margin-bottom: 8px; }
  .benefit p { font-size: .95rem; margin: 0; }
  @media (max-width: 640px) {
    .benefit { padding: 0; }
    .benefit-icon { width: 52px; height: 52px; font-size: 1.4rem; margin-bottom: 14px; }
  }

  /* CTA */
  .cta-section { padding-bottom: 0; }
  .cta-box {
    position: relative;
    background: var(--c-black);
    color: #fff;
    border-radius: var(--r-xl);
    padding: 80px 40px;
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }
  @media (max-width: 640px) {
    .cta-box { padding: 48px 24px; border-radius: var(--r-lg); }
    .cta-box .btn { width: 100%; }
  }
  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(229,9,20,0.4) 0%, transparent 60%);
    z-index: -1;
    animation: drift 16s ease-in-out infinite;
  }
  .cta-box h2 {
    color: #fff;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    margin-bottom: 12px;
  }
  .cta-box p {
    color: rgba(255,255,255,0.75);
    font-size: 1.1rem;
    max-width: 560px;
    margin: 0 auto 28px;
  }
</style>

<script>
  // Mouse-parallax для hero фон (только desktop, не reduced motion)
  const hero = document.getElementById('hero');
  const heroBg = document.getElementById('hero-bg');
  if (hero && heroBg && !window.matchMedia('(prefers-reduced-motion: reduce)').matches && window.matchMedia('(pointer: fine)').matches) {
    hero.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      heroBg.style.transform = `translate(${x * 20}px, ${y * 20}px)`;
    });
    hero.addEventListener('mouseleave', () => {
      heroBg.style.transform = 'translate(0,0)';
    });
  }
</script>
