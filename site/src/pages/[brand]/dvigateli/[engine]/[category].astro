---
import Base from '../../../../layouts/Base.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import {
  getEngines,
  getEnginePartsIndex,
  getVariantSizes,
  getStock,
  getPartNumbers,
  getAttributes,
} from '../../../../lib/db';
import { brandSlug, engineSlug, categorySlug, categoryFromSlug } from '../../../../lib/slugs';
import { categoryLabel, brandDisplay, insertTypeLabel } from '../../../../lib/labels';
// Цены временно скрыты — выводим только характеристики, размеры и артикулы.

export async function getStaticPaths() {
  const engines = await getEngines();
  const partsIdx = await getEnginePartsIndex();
  const engByCode = new Map(engines.map((e) => [e.engine_code, e]));
  return partsIdx
    .map((p) => {
      const eng = engByCode.get(p.engine_code);
      if (!eng) return null;
      const catSl = categorySlug[p.category_code];
      if (!catSl) return null;
      return {
        params: {
          brand: brandSlug[eng.brand_name] ?? eng.brand_name.toLowerCase(),
          engine: engineSlug(eng.engine_code),
          category: catSl,
        },
        props: { engine: eng, categoryCode: p.category_code },
      };
    })
    .filter((x): x is NonNullable<typeof x> => x !== null);
}

const { engine, categoryCode } = Astro.props;
const catLabel = categoryLabel[categoryCode];

const [variants, numbers, attrs] = await Promise.all([
  getVariantSizes(engine.engine_code, categoryCode),
  getPartNumbers(engine.engine_code, categoryCode),
  getAttributes(engine.engine_code, categoryCode),
]);

const attrMap = Object.fromEntries(
  attrs.map((a) => [a.attribute_code, a.value_text ?? a.value_number ?? a.value_integer])
);

// Группируем варианты: бренд → тип вставки → набор доступных размеров (без цен/остатков)
type Variant = {
  brand: string;
  insertType: string;
  sizes: Set<string>;
};
const variantMap = new Map<string, Variant>();
for (const v of variants) {
  const key = `${v.brand_name}|${v.insert_type}`;
  if (!variantMap.has(key)) {
    variantMap.set(key, { brand: v.brand_name, insertType: v.insert_type, sizes: new Set() });
  }
  variantMap.get(key)!.sizes.add(v.size_code);
}
const variantList = [...variantMap.values()].sort(
  (a, b) => a.brand.localeCompare(b.brand) || a.insertType.localeCompare(b.insertType)
);

// Все размеры, которые встречаются у этого двигателя
const allSizes = new Set<string>();
for (const v of variantList) for (const s of v.sizes) allSizes.add(s);
const sizesOrder = ['STD', '0.25', '0.50', '0.75', '1.00'];
const availableSizes = sizesOrder.filter((s) => allSizes.has(s));

// Брендов запчастей под этот двигатель
const partsBrandList = [...new Set(variantList.map((v) => v.brand))];

const oemNumbers = numbers.filter((n) => n.number_type === 'oem' || n.number_type === 'alt_oem');
const tknNumbers = numbers.filter((n) => n.number_type === 'teikin');
const catalogNumbers = numbers.filter((n) => n.number_type.startsWith('catalog_'));

const brandSl = brandSlug[engine.brand_name] ?? engine.brand_name.toLowerCase();
const engSl = engineSlug(engine.engine_code);

// Список других категорий для этого двигателя (для внутренней перелинковки)
const allPartsIdx = await getEnginePartsIndex();
const otherCategories = allPartsIdx
  .filter((p) => p.engine_code === engine.engine_code && p.category_code !== categoryCode)
  .map((p) => p.category_code);

// SEO: оптимизированные тексты под запросы вида "{категория} {код двигателя}"
const catLower = catLabel.toLowerCase();
const seoTitle = `${catLabel} ${engine.brand_name} ${engine.engine_code} купить в Алматы — ${partsBrandList[0] || 'TEIKIN'} | MY AVTO`;
const seoDesc = `${catLabel} на двигатель ${engine.brand_name} ${engine.engine_code}${engine.volume_l ? `, ${engine.volume_l} л` : ''}. Бренды: ${partsBrandList.join(', ') || 'TEIKIN, NPR, IZUMI'}. Размеры: ${availableSizes.join(', ') || 'STD, 0.25, 0.50'}. Магазин в Алматы, доставка по Казахстану.`;
const seoKw = [
  `${catLower} ${engine.engine_code.toLowerCase()}`,
  `${engine.engine_code.toLowerCase()} ${catLower}`,
  `${catLower} ${engine.engine_code.toLowerCase()} алматы`,
  `купить ${catLower} ${engine.engine_code.toLowerCase()}`,
  `${engine.brand_name.toLowerCase()} ${engine.engine_code.toLowerCase()} капремонт`,
  ...(partsBrandList.length ? partsBrandList.map((b) => `${engine.engine_code.toLowerCase()} ${b.toLowerCase()}`) : []),
].join(', ');

// FAQ под эту категорию + двигатель (генерируется автоматически)
const faqItems = [
  {
    q: `Какие ${catLower} подходят на двигатель ${engine.brand_name} ${engine.engine_code}?`,
    a: `На двигатель ${engine.brand_name} ${engine.engine_code} подходят ${catLower} брендов ${partsBrandList.length ? partsBrandList.join(', ') : 'TEIKIN, NPR, IZUMI, Taiho'}. ${attrMap.piston_diameter ? `Стандартный диаметр поршня — Ø${attrMap.piston_diameter} мм. ` : ''}Доступные ремонтные размеры: ${availableSizes.join(', ') || 'STD, 0.25, 0.50, 0.75, 1.00'}.`,
  },
  {
    q: `Какой размер ${catLower} выбрать для ${engine.engine_code}?`,
    a: `Если двигатель ${engine.engine_code} не растачивался — берите STD (стандарт). После расточки блока цилиндров — соответствующий ремонтный размер: 0.25, 0.50, 0.75 или 1.00 мм. Точный размер скажет моторист после замера цилиндров.`,
  },
  {
    q: `Сколько стоят ${catLower} на ${engine.brand_name} ${engine.engine_code}?`,
    a: `Цена зависит от бренда и размера. Напишите в WhatsApp +7 701 550 9377 — пришлём актуальную цену за 10 минут. У нас цены ниже рынка на 15-20%, потому что работаем напрямую с поставщиками из Японии.`,
  },
  {
    q: `Есть ли ${catLower} в наличии в Алматы?`,
    a: `Большинство позиций в наличии в магазине Алматы (ТЦ CarCity, 3 ярус, бутик 135В). Редкие размеры — под заказ из Японии, срок 3-7 дней. Точное наличие проверим по коду двигателя в WhatsApp.`,
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Главная', item: 'https://my-avto.kz/' },
      { '@type': 'ListItem', position: 2, name: engine.brand_name, item: `https://my-avto.kz/${brandSl}/` },
      { '@type': 'ListItem', position: 3, name: engine.engine_code, item: `https://my-avto.kz/${brandSl}/dvigateli/${engSl}/` },
      { '@type': 'ListItem', position: 4, name: catLabel },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: `${catLabel} ${engine.brand_name} ${engine.engine_code}`,
    description: seoDesc,
    category: catLabel,
    brand: partsBrandList.length ? partsBrandList.map((b) => ({ '@type': 'Brand', name: b })) : [{ '@type': 'Brand', name: 'TEIKIN' }],
    image: 'https://my-avto.kz/assets/og-image.jpg',
    sku: tknNumbers[0]?.number_value || oemNumbers[0]?.number_value || `${engine.engine_code}-${categoryCode}`,
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'KZT',
      availability: 'https://schema.org/InStock',
      seller: { '@type': 'AutoPartsStore', name: 'MY AVTO' },
      url: `https://my-avto.kz/${brandSl}/dvigateli/${engSl}/${categorySlug[categoryCode]}/`,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Base
  title={seoTitle}
  description={seoDesc}
  keywords={seoKw}
  jsonLd={jsonLd}
>
  <!-- Hero header — dark slice -->
  <div class="page-hero">
    <div class="page-hero-bg">
      <div class="ph-glow"></div>
    </div>
    <div class="container">
      <Breadcrumbs items={[
        { name: 'Главная', href: '/' },
        { name: engine.brand_name, href: `/${brandSl}/` },
        { name: engine.engine_code, href: `/${brandSl}/dvigateli/${engSl}/` },
        { name: catLabel },
      ]} />
      <div class="ph-content reveal">
        <div class="ph-tags">
          <span class="ph-tag">{engine.brand_name}</span>
          <span class="ph-tag">{engine.engine_code}</span>
          {engine.volume_l && <span class="ph-tag">{engine.volume_l} л</span>}
          {engine.is_diesel && <span class="ph-tag">Дизель</span>}
        </div>
        <h1>
          {catLabel} на двигатель<br />
          <span class="accent-text">{engine.brand_name} {engine.engine_code}</span>
        </h1>
        <p class="ph-lead">
          Купить {catLower} {engine.engine_code} в Алматы. {partsBrandList.length > 0 ? `Бренды: ${partsBrandList.map(brandDisplay).join(', ')}.` : 'Бренды TEIKIN, NPR, IZUMI, Taiho в наличии.'} Размеры: {availableSizes.length > 0 ? availableSizes.join(', ') : 'STD, 0.25, 0.50, 0.75, 1.00'}.
        </p>
        <div class="ph-meta">
          <a href="https://wa.me/77015509377" class="btn">Узнать цену в WhatsApp</a>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <section class="reveal">
      <h2>Технические характеристики двигателя</h2>
      <div class="specs-table">
        <div class="spec-row">
          <div class="spec-row-label">Марка авто</div>
          <div class="spec-row-val">{engine.brand_name}</div>
        </div>
        <div class="spec-row">
          <div class="spec-row-label">Код двигателя</div>
          <div class="spec-row-val mono"><strong>{engine.engine_code}</strong></div>
        </div>
        {engine.volume_l && (
          <div class="spec-row">
            <div class="spec-row-label">Объём двигателя</div>
            <div class="spec-row-val">{engine.volume_l} л</div>
          </div>
        )}
        {engine.cylinder_count && (
          <div class="spec-row">
            <div class="spec-row-label">Количество цилиндров</div>
            <div class="spec-row-val">{engine.cylinder_count}</div>
          </div>
        )}
        {engine.valve_count && (
          <div class="spec-row">
            <div class="spec-row-label">Клапанов</div>
            <div class="spec-row-val">{engine.valve_count}</div>
          </div>
        )}
        <div class="spec-row">
          <div class="spec-row-label">Тип топлива</div>
          <div class="spec-row-val">{engine.is_diesel ? 'Дизель' : 'Бензин'}</div>
        </div>
        {attrMap.piston_diameter && (
          <div class="spec-row">
            <div class="spec-row-label">Диаметр поршня</div>
            <div class="spec-row-val">Ø {attrMap.piston_diameter} мм</div>
          </div>
        )}
        {attrMap.pin_diameter && (
          <div class="spec-row">
            <div class="spec-row-label">Диаметр пальца</div>
            <div class="spec-row-val">Ø {attrMap.pin_diameter} мм</div>
          </div>
        )}
        {attrMap.piston_spec_raw && (
          <div class="spec-row">
            <div class="spec-row-label">Спецификация поршня</div>
            <div class="spec-row-val mono">{attrMap.piston_spec_raw}</div>
          </div>
        )}
      </div>
    </section>

    {variantList.length > 0 && (
      <section class="reveal">
        <h2>Доступные бренды и размеры</h2>
        <p class="muted">
          Под этот двигатель подходят {catLabel.toLowerCase()} следующих брендов.
          Цена и точное наличие — по запросу.
        </p>
        <div class="variants-grid">
          {variantList.map((v) => (
            <div class="variant-card">
              <div class="variant-head">
                <strong class="variant-brand">{brandDisplay(v.brand)}</strong>
                <span class="badge">{insertTypeLabel[v.insertType] ?? v.insertType}</span>
              </div>
              <div class="variant-sizes">
                {sizesOrder.filter((s) => v.sizes.has(s)).map((s) => (
                  <span class="size-chip">{s}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
        <p class="price-note muted small">
          STD — стандартный заводской размер. 0.25 / 0.50 / 0.75 / 1.00 — ремонтные размеры
          (диаметр после расточки больше штатного на соответствующую величину в мм).
        </p>
      </section>
    )}

    {(oemNumbers.length > 0 || tknNumbers.length > 0 || catalogNumbers.length > 0) && (
      <section class="reveal">
        <h2>Каталожные номера</h2>
        <div class="numbers-grid">
          {oemNumbers.length > 0 && (
            <div>
              <div class="num-title">OEM номера</div>
              <div class="numbers">{oemNumbers.map((n) => <span class="number">{n.number_value}</span>)}</div>
            </div>
          )}
          {tknNumbers.length > 0 && (
            <div>
              <div class="num-title">Номера TEIKIN</div>
              <div class="numbers">{tknNumbers.map((n) => <span class="number">TKN {n.number_value}</span>)}</div>
            </div>
          )}
          {catalogNumbers.length > 0 && (
            <div>
              <div class="num-title">Каталог производителей</div>
              <div class="numbers">{catalogNumbers.map((n) => <span class="number">{n.number_value}</span>)}</div>
            </div>
          )}
        </div>
      </section>
    )}

    <section class="reveal">
      <h2>Что важно знать о {catLower} на {engine.engine_code}</h2>
      <p>
        Двигатель <strong>{engine.brand_name} {engine.engine_code}</strong>
        {engine.volume_l && <> объёмом {engine.volume_l} л</>}
        {engine.cylinder_count && <>, {engine.cylinder_count}-цилиндровый</>}
        {engine.is_diesel ? ' (дизель)' : ' (бензин)'}
        {attrMap.piston_diameter && <> со стандартным диаметром поршня Ø{attrMap.piston_diameter} мм</>}.
        При капитальном ремонте двигателя {engine.engine_code} {catLower} подбираются под фактический
        размер расточки блока цилиндров — STD для нерастачиваемых, 0.25/0.50/0.75/1.00 мм для
        ремонтных. Перед заказом моторист замеряет цилиндры и определяет нужный размер.
      </p>
      <p>
        В нашем магазине представлены {catLower} брендов
        {' '}<strong>{partsBrandList.length > 0 ? partsBrandList.map(brandDisplay).join(', ') : 'TEIKIN, IZUMI, NPR, RIK, TP, ND, Taiho'}</strong> —
        японские производители с гарантией оригинала. Поставка напрямую без посредников,
        поэтому цены ниже рынка на 15-20%. Оригинальные {catLower} {engine.brand_name} —
        под заказ из Японии (срок 7-14 дней).
      </p>
      {oemNumbers.length > 0 && (
        <p>
          OEM номера для подбора: {oemNumbers.slice(0, 3).map((n) => <code>{n.number_value}</code>).reduce((a, b, i) => i === 0 ? [b] : [...a, ', ', b], [] as any)}.
          Если у вас есть свой номер запчасти — пришлите в WhatsApp, подберём аналог.
        </p>
      )}
    </section>

    {otherCategories.length > 0 && (
      <section class="reveal related-cats">
        <h2>Другие запчасти на двигатель {engine.engine_code}</h2>
        <p class="muted">Полный комплект для капремонта {engine.brand_name} {engine.engine_code}:</p>
        <div class="related-grid">
          {otherCategories.map((cc) => (
            <a href={`/${brandSl}/dvigateli/${engSl}/${categorySlug[cc]}/`} class="related-card">
              <strong>{categoryLabel[cc]}</strong>
              <span>на {engine.brand_name} {engine.engine_code} →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="reveal faq-section">
      <h2>Частые вопросы про {catLower} {engine.engine_code}</h2>
      <div class="faq-list">
        {faqItems.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-box reveal">
        <div class="cta-glow"></div>
        <div class="cta-content">
          <h2>Узнать цену и наличие</h2>
          <p>Напишите код двигателя и нужный размер — пришлём цену и сроки в WhatsApp.</p>
          <a href={`https://wa.me/77015509377?text=Здравствуйте,%20нужны%20${encodeURIComponent(catLabel.toLowerCase())}%20на%20${engine.brand_name}%20${engine.engine_code}`} class="btn" target="_blank" rel="noopener noreferrer">Написать в WhatsApp</a>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .page-hero {
    position: relative;
    background: var(--c-black);
    color: #fff;
    padding: 24px 0 64px;
    overflow: hidden;
    isolation: isolate;
    margin-bottom: 48px;
  }
  .page-hero-bg { position: absolute; inset: 0; z-index: -1; }
  .ph-glow {
    position: absolute;
    width: 700px; height: 400px;
    top: -100px; right: -200px;
    background: radial-gradient(ellipse, rgba(229,9,20,0.35) 0%, transparent 60%);
    filter: blur(60px);
  }
  @media (max-width: 768px) {
    .ph-glow { width: 360px; height: 220px; top: -60px; right: -80px; filter: blur(40px); }
  }
  .page-hero :global(.breadcrumbs) { padding-top: 16px; }
  .page-hero :global(.breadcrumbs a) { color: rgba(255,255,255,0.6); }
  .page-hero :global(.breadcrumbs a:hover) { color: var(--c-red); }
  .page-hero :global(.breadcrumbs .sep) { color: rgba(255,255,255,0.3); }
  .page-hero :global(.breadcrumbs [aria-current="page"]) { color: #fff; }
  .ph-content { padding-top: 24px; max-width: 800px; }
  .ph-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .ph-tag {
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    font-size: .78rem;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
  }
  .page-hero h1 {
    color: #fff;
    margin-bottom: 16px;
    font-size: clamp(2rem, 4.5vw, 3.6rem);
  }
  .ph-lead { color: rgba(255,255,255,0.75); font-size: 1.1rem; max-width: 700px; }
  .ph-meta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 24px; }
  .ph-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 999px;
    background: rgba(22,163,74,0.15);
    border: 1px solid rgba(22,163,74,0.4);
    color: #4ade80;
    font-weight: 500;
    font-size: .9rem;
  }
  .ph-dot {
    width: 8px; height: 8px;
    background: #4ade80;
    border-radius: 50%;
    box-shadow: 0 0 8px #4ade80;
  }
  .accent-text {
    background: linear-gradient(135deg, var(--c-red) 0%, #ff5760 60%, #ff8a92 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .specs-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0;
    background: var(--c-bg-soft);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    overflow: hidden;
    margin-bottom: 48px;
  }
  .spec-item { padding: 20px 24px; border-right: 1px solid var(--c-border); }
  .spec-item:last-child { border-right: 0; }
  .spec-label {
    font-size: .76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-text-faint);
    font-weight: 600;
    margin-bottom: 6px;
  }
  .spec-val { font-size: 1.1rem; font-weight: 700; }
  .spec-val.mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: .95rem; }

  .price-note { margin: 16px 0 0; }

  /* Specs table */
  .specs-table {
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    overflow: hidden;
    margin-bottom: 16px;
  }
  .spec-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--c-border);
  }
  .spec-row:last-child { border-bottom: 0; }
  .spec-row-label { color: var(--c-text-dim); font-size: .94rem; }
  .spec-row-val { font-weight: 600; color: var(--c-text); }
  .spec-row-val.mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }
  @media (max-width: 540px) {
    .spec-row { grid-template-columns: 1fr; gap: 4px; padding: 12px 16px; }
    .spec-row-label { font-size: .82rem; }
  }

  /* Variant cards */
  .variants-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    margin-top: 20px;
  }
  .variant-card {
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    padding: 16px 18px;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
